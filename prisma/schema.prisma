// Rocket PM Dashboard — Phase 0 schema (multi-tenant foundation + forward-looking models)
// Organization scoping: business rows use organizationId; session always carries activeOrgId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Identity (Path A / PR2): staff roles + org membership; platform operators separate ---

/// Canonical staff/tenant role keys (seed all rows). Property-scoped access uses UserPropertyAssignment (later PR).
enum RoleKey {
  administrator
  property_manager
  field_agent
  tenant
}

model Role {
  id   String  @id @default(cuid())
  key  RoleKey @unique
  name String

  usersPrimary        User[]                   @relation("UserPrimaryRole")
  propertyAssignments UserPropertyAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  passwordHash String?
  firstName    String?
  lastName     String?
  isActive     Boolean @default(true)

  primaryRoleId String?
  primaryRole   Role?   @relation("UserPrimaryRole", fields: [primaryRoleId], references: [id], onDelete: SetNull)

  /// Rocket Logic staff: may list/switch orgs; queries still scoped by active organizationId.
  platformAccessLevel PlatformAccessLevel @default(NONE)

  memberships                 OrganizationMembership[]
  propertyAssignments         UserPropertyAssignment[]
  showingsAssigned            Showing[]                @relation("ShowingAssignedTo")
  showingsCreated             Showing[]                @relation("ShowingCreatedBy")
  applicationsReviewed        Application[]            @relation("ApplicationReviewedBy")
  clientProfilesCreated       ClientProfile[]          @relation("ClientProfileCreatedBy")
  activityLogEntries          ActivityLog[]            @relation("ActivityLogActor")
  maintenanceRequestsAssigned MaintenanceRequest[]     @relation("MaintenanceRequestAssignedTo")
  auditLogs                   AuditLog[]
  backgroundJobsTriggered     BackgroundJob[] @relation("BackgroundJobTriggeredBy")
  agentRunsCreated            AgentRun[]      @relation("AgentRunCreatedBy")
  connectedEmailAccounts         ConnectedEmailAccount[]
  emailSenderCategoryMemories    EmailSenderCategoryMemory[]
  styleExamples                  AiStyleExample[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryRoleId])
}

// --- Tenancy ---

model Organization {
  id   String @id @default(cuid())
  name String
  slug String @unique

  /// BC RTB-1 landlord / service-of-documents profile (org-wide).
  landlordLegalName            String?
  landlordServiceStreetLine1   String?
  landlordServiceStreetLine2   String?
  landlordServiceCity          String?
  landlordServiceProvince      String?  @default("BC")
  landlordServicePostalCode    String?
  landlordServicePhone         String?
  landlordServiceEmail         String?
  landlordIsAgent              Boolean  @default(false)

  memberships OrganizationMembership[]
  properties  Property[]

  maintenanceRequests    MaintenanceRequest[]
  maintenanceAttachments MaintenanceAttachment[]
  auditLogs              AuditLog[]
  connectedEmailAccounts      ConnectedEmailAccount[]
  emailThreads                EmailThread[]
  emailMessages               EmailMessage[]
  emailSenderCategoryMemories EmailSenderCategoryMemory[]
  knowledgeSources       AiKnowledgeSource[]
  responderRules         AiResponderRule[]
  styleExamples          AiStyleExample[]
  draftResponses         AiDraftResponse[]
  backgroundJobs         BackgroundJob[]
  agentRuns                AgentRun[]
  aiPolicy                 OrganizationAiPolicy?
  rentalAdAssistantDrafts  RentalAdAssistantDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Per-organization membership role (not Rocket Logic platform access).
enum OrganizationMembershipRole {
  ADMIN
  MEMBER
  /// Reserved for future SaaS/billing org owner — not used for Rocket Logic operators.
  OWNER
}

/// Rocket Logic operator flag (separate from per-org roles).
enum PlatformAccessLevel {
  NONE
  OPERATOR
}

model OrganizationMembership {
  id             String                     @id @default(cuid())
  userId         String
  organizationId String
  role           OrganizationMembershipRole @default(MEMBER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
}

// --- Property graph (Path A / PR3): org-scoped properties, units, staff assignments ---

model Property {
  id          String  @id @default(cuid())
  name        String
  streetLine1 String
  streetLine2 String?
  city        String
  province    String  @default("BC")
  postalCode  String
  country     String  @default("CA")
  isActive    Boolean @default(true)

  /// Rental profile — not official rent or lease data.
  propertyType String?
  bedrooms     Int?
  bathrooms    Decimal? @db.Decimal(4, 1)
  approxSqft   Int?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  units                Unit[]
  assignments          UserPropertyAssignment[]
  prospects            Prospect[]
  showings             Showing[]
  applications         Application[]
  applicationDocuments ApplicationDocument[]
  tenancies            Tenancy[]
  notices              Notice[]
  generalDocuments     Document[]               @relation("DocumentProperty")
  signatureRequests    SignatureRequest[]
  checklists           Checklist[]
  activityLogs              ActivityLog[]
  maintenanceRequests       MaintenanceRequest[]
  rentalAdAssistantDrafts   RentalAdAssistantDraft[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city])
  @@index([organizationId])
}

model Unit {
  id         String  @id @default(cuid())
  propertyId String
  unitNumber String
  floor      String?
  bedrooms   Int?
  isActive   Boolean @default(true)

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  prospects           Prospect[]
  showings            Showing[]
  applications        Application[]
  tenancies           Tenancy[]
  notices             Notice[]
  generalDocuments          Document[]                @relation("DocumentUnit")
  maintenanceRequests       MaintenanceRequest[]
  rentalAdAssistantDraft    RentalAdAssistantDraft?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
}

/// Draft-only workspace for the Rental Ad Assistant (not official property or rent data).
model RentalAdAssistantDraft {
  id             String @id @default(cuid())
  organizationId String
  propertyId     String
  unitId         String @unique

  createdByUserId String?
  updatedByUserId String?

  /// PM-entered temporary ad details — NOT official property/unit fields.
  inputsJson Json

  /// AI-generated + PM-edited advertising content — NOT official rent.
  outputJson Json?

  /// Snapshot of internal historical lease comps used at last generation.
  compsSnapshotJson Json?

  model           String?
  promptVersion   String?
  lastGeneratedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, propertyId])
  @@index([organizationId, updatedAt])
}

/// Scopes property_manager and field_agent staff to specific properties within an org.
model UserPropertyAssignment {
  id         String @id @default(cuid())
  userId     String
  propertyId String
  roleId     String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, propertyId, roleId])
  @@index([userId])
  @@index([propertyId])
}

// --- Leasing & tenancy (Path A / PR4) ---

enum ProspectStatus {
  new
  archived
}

enum ShowingStatus {
  scheduled
  completed
  no_show
  cancelled
}

enum ShowingOutcome {
  interested
  not_interested
  no_show
  reschedule
}

enum ContactStatus {
  not_contacted
  contacted
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  approved
  declined
  withdrawn
}

enum TenancyStatus {
  pending_move_in
  active
  notice_received
  move_out_scheduled
  inspection_scheduled
  inspection_completed
  ended
  archived
}

enum RetentionStatus {
  archived
  pending_review
  converted_to_client
  scheduled_for_deletion
  deleted
}

enum TenancyContactType {
  tenant
  co_tenant
  occupant
  emergency_contact
}

model Prospect {
  id         String  @id @default(cuid())
  propertyId String
  unitId     String?

  email     String
  firstName String?
  lastName  String?
  phone     String?

  /// Public viewing-request intake (master record until application snapshot).
  occupantCount         Int?
  hasPets               Boolean   @default(false)
  petDetails            String?   @db.Text
  smokerStatus          String?
  householdIncomeRange  String?
  desiredMoveInDate     DateTime? @db.Date
  preferredViewingNotes String?   @db.Text
  message               String?   @db.Text

  status ProspectStatus @default(new)

  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         Unit?         @relation(fields: [unitId], references: [id], onDelete: SetNull)
  showings     Showing[]
  applications Application[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([email])
  @@index([propertyId, email])
}

model Showing {
  id         String  @id @default(cuid())
  prospectId String
  propertyId String
  unitId     String?

  assignedToUserId String?
  createdByUserId  String?

  scheduledStart DateTime
  scheduledEnd   DateTime?

  status         ShowingStatus   @default(scheduled)
  showingOutcome ShowingOutcome?
  contactStatus  ContactStatus   @default(not_contacted)
  contactNotes   String?         @db.Text

  prospect   Prospect @relation(fields: [prospectId], references: [id], onDelete: Restrict)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit       Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  assignedTo User?    @relation("ShowingAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User?    @relation("ShowingCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([prospectId])
  @@index([propertyId])
  @@index([assignedToUserId])
  @@index([scheduledStart])
}

model Application {
  id         String  @id @default(cuid())
  propertyId String
  unitId     String
  prospectId String?

  email String

  firstName         String?
  lastName          String?
  phone             String?
  currentAddress    String?   @db.Text
  desiredMoveInDate DateTime? @db.Date

  occupantCount Int?
  monthlyIncome Decimal? @db.Decimal(12, 2)

  hasPets    Boolean @default(false)
  petDetails String? @db.Text

  smokerStatus String?

  employerName    String?
  jobTitle        String?
  employmentNotes String? @db.Text

  emergencyContactFirstName String?
  emergencyContactLastName  String?
  emergencyContactPhone     String?
  emergencyContactEmail     String?

  consentCreditCheck   Boolean   @default(false)
  consentSignatureName String?
  consentSignedAt      DateTime?
  consentIpAddress     String?   @db.VarChar(45)
  consentUserAgent     String?   @db.Text

  status ApplicationStatus @default(draft)

  submittedAt      DateTime?
  reviewedByUserId String?
  decisionAt       DateTime?

  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit       Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  reviewedBy User?     @relation("ApplicationReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  documents         ApplicationDocument[]
  generalDocuments  Document[]            @relation("DocumentApplication")
  signatureRequests SignatureRequest[]    @relation("SignatureRequestApplication")
  tenancy           Tenancy?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([unitId])
  @@index([email])
  @@index([propertyId, email])
  @@index([prospectId])
  @@index([status])
  @@index([submittedAt])
}

model ApplicationDocument {
  id            String @id @default(cuid())
  applicationId String
  propertyId    String

  fileName     String
  contentType  String?
  sizeBytes    Int
  storageKey   String  @unique
  documentKind String?

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([propertyId])
}

model Tenancy {
  id            String @id @default(cuid())
  propertyId    String
  unitId        String
  applicationId String @unique

  status TenancyStatus @default(pending_move_in)

  leaseStartDate DateTime  @db.Date
  leaseEndDate   DateTime? @db.Date
  moveInDate     DateTime  @db.Date
  /// Confirmed scheduled vacate date (set when staff schedules move-out after notice acceptance).
  moveOutDate    DateTime? @db.Date

  /// Move-out inspection workflow (staff-entered; not synced externally).
  inspectionDate      DateTime? @db.Date
  inspectionReportUrl String?   @db.Text
  inspectionNotes     String?   @db.Text

  /// Day of month (1–31) when each rental period begins; used for notice and move-out date validation.
  rentDueDay Int @default(1)

  monthlyRent     Decimal  @db.Decimal(12, 2)
  securityDeposit Decimal  @db.Decimal(12, 2)
  petDeposit      Decimal? @db.Decimal(12, 2)

  /// RTB-1 lease setup fields completed by property management before document generation.
  leaseSetupJson Json?

  buildiumResidentCenterUrl String? @db.Text

  archivedAt           DateTime?
  retentionReviewDueAt DateTime?
  retentionStatus      RetentionStatus?

  property    Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit        Unit        @relation(fields: [unitId], references: [id], onDelete: Restrict)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Restrict)

  contacts              TenancyContact[]
  notices               Notice[]
  generalDocuments      Document[]           @relation("DocumentTenancy")
  signatureRequests     SignatureRequest[]   @relation("SignatureRequestTenancy")
  checklists            Checklist[]          @relation("ChecklistTenancy")
  sourcedClientProfiles ClientProfile[]      @relation("ClientProfileSourceTenancy")
  maintenanceRequests   MaintenanceRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([unitId])
  @@index([status])
  @@index([archivedAt])
  @@index([retentionReviewDueAt])
  @@index([retentionStatus])
}

model TenancyContact {
  id        String @id @default(cuid())
  tenancyId String

  firstName String
  lastName  String
  email     String
  phone     String?

  contactType TenancyContactType

  portalAccessEnabled Boolean @default(false)

  tenancy                      Tenancy              @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  maintenanceRequestsSubmitted MaintenanceRequest[]
  leaseSignatures              LeaseSignature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenancyId])
  @@index([email])
  @@index([tenancyId, email])
}

/// One-time tenant portal sign-in code (hashed). One active challenge per normalized email.
model TenantOtpChallenge {
  id        String   @id @default(cuid())
  email     String
  contactId String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email])
  @@index([expiresAt])
}

/// Notice served or filed for a tenancy. noticeType is app-level vocabulary (string), not an enum.
model Notice {
  id         String  @id @default(cuid())
  propertyId String
  unitId     String?
  tenancyId  String

  noticeType String
  title      String
  body       String @db.Text

  serviceMethod String?
  servedAt      DateTime?

  /// Tenant-selected tenancy end date (rental-period boundary). Not stored in body.
  tenantRequestedMoveOutDate DateTime? @db.Date

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  tenancy  Tenancy  @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([unitId])
  @@index([tenancyId])
  @@index([servedAt])
}

// --- Documents & operations (Path A / PR5) ---
// AuditLog (below) = security/integration (Gmail, AI). ActivityLog = domain entity change history.

enum SignatureRequestStatus {
  draft
  sent
  viewed
  completed
  cancelled
  failed
}

enum LeaseSignatureRole {
  tenant
  property_manager
}

enum ChecklistStatus {
  not_started
  in_progress
  complete
}

enum ChecklistItemStatus {
  pending
  complete
  waived
}

enum ClientProfileSourceType {
  former_tenant
  prospect
  manual
}

/// General file metadata (object storage). Distinct from ApplicationDocument on applications.
model Document {
  id            String  @id @default(cuid())
  propertyId    String
  unitId        String?
  tenancyId     String?
  applicationId String?

  documentType String
  title        String
  fileName     String

  contentType String?
  sizeBytes   Int?

  storageKey String @unique

  isSigned Boolean @default(false)
  isLocked Boolean @default(false)

  property    Property     @relation("DocumentProperty", fields: [propertyId], references: [id], onDelete: Cascade)
  unit        Unit?        @relation("DocumentUnit", fields: [unitId], references: [id], onDelete: SetNull)
  tenancy     Tenancy?     @relation("DocumentTenancy", fields: [tenancyId], references: [id], onDelete: SetNull)
  application Application? @relation("DocumentApplication", fields: [applicationId], references: [id], onDelete: SetNull)

  signatureRequestsAsDraft    SignatureRequest[] @relation("SignatureRequestDraftDocument")
  signatureRequestsAsExecuted SignatureRequest[] @relation("SignatureRequestExecutedDocument")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([unitId])
  @@index([tenancyId])
  @@index([applicationId])
  @@index([documentType])
}

/// Outbound e-sign envelope. Exactly one of tenancyId or applicationId should be set (enforce in services).
model SignatureRequest {
  id            String  @id @default(cuid())
  propertyId    String
  tenancyId     String?
  applicationId String?

  provider          String
  providerRequestId String?

  status SignatureRequestStatus @default(draft)

  sentAt      DateTime?
  completedAt DateTime?

  /// RTB-1 draft document sent for signature.
  documentId String?
  /// Flattened executed RTB-1 after all signatures.
  executedDocumentId String?

  /// SHA-256 hash of the tenant signing token (never store raw token).
  signingTokenHash      String?   @unique
  signingTokenExpiresAt DateTime?

  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancy          Tenancy?          @relation("SignatureRequestTenancy", fields: [tenancyId], references: [id], onDelete: Cascade)
  application      Application?      @relation("SignatureRequestApplication", fields: [applicationId], references: [id], onDelete: Cascade)
  draftDocument    Document?         @relation("SignatureRequestDraftDocument", fields: [documentId], references: [id], onDelete: SetNull)
  executedDocument Document?         @relation("SignatureRequestExecutedDocument", fields: [executedDocumentId], references: [id], onDelete: SetNull)
  signatures       LeaseSignature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([tenancyId])
  @@index([applicationId])
  @@index([status])
  @@index([provider])
  @@index([documentId])
}

/// In-app lease signature audit record (tenant or property manager).
model LeaseSignature {
  id                 String             @id @default(cuid())
  signatureRequestId String
  signerRole         LeaseSignatureRole
  signerName         String
  signedAt           DateTime
  ipAddress          String?
  userAgent          String?            @db.Text
  signatureImageStorageKey String
  tenancyContactId   String?

  signatureRequest SignatureRequest @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)
  tenancyContact   TenancyContact?  @relation(fields: [tenancyContactId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([signatureRequestId, signerRole])
  @@index([signatureRequestId])
  @@index([tenancyContactId])
}

model Checklist {
  id         String  @id @default(cuid())
  propertyId String
  tenancyId  String?

  checklistType String

  status ChecklistStatus @default(not_started)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancy  Tenancy? @relation("ChecklistTenancy", fields: [tenancyId], references: [id], onDelete: Cascade)

  items ChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([tenancyId])
  @@index([status])
  @@index([checklistType])
}

model ChecklistItem {
  id          String @id @default(cuid())
  checklistId String

  itemKey String
  label   String

  isRequired Boolean @default(true)

  status ChecklistItemStatus @default(pending)

  completedAt DateTime?

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([checklistId, itemKey])
  @@index([checklistId])
  @@index([status])
}

model ClientProfile {
  id String @id @default(cuid())

  firstName String
  lastName  String
  email     String
  phone     String

  city  String?
  notes String? @db.Text

  employerName    String?
  jobTitle        String?
  monthlyIncome   Decimal? @db.Decimal(12, 2)
  employmentNotes String?  @db.Text

  sourceType ClientProfileSourceType

  sourceTenancyId String?
  createdByUserId String?

  sourceTenancy Tenancy? @relation("ClientProfileSourceTenancy", fields: [sourceTenancyId], references: [id], onDelete: SetNull)
  createdBy     User?    @relation("ClientProfileCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([sourceType])
  @@index([sourceTenancyId])
  @@index([createdByUserId])
}

/// Domain entity audit (tenancy, application, etc.). Not Gmail/AI security events — see AuditLog.
model ActivityLog {
  id String @id @default(cuid())

  propertyId  String?
  actorUserId String?

  entityType String
  entityId   String
  action     String

  oldValues Json?
  newValues Json?

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  actor    User?     @relation("ActivityLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([action])
}

// --- Maintenance (Path A / PR6): unified Prisma SoT — tables MaintenanceRequest / MaintenanceAttachment only.
// Do NOT @@map to maintenance_requests (Supabase legacy table in donor repo).

enum MaintenanceRequestStatus {
  new
  triaged
  dispatched
  in_progress
  awaiting_owner_approval
  scheduled
  completed
  cancelled
}

enum MaintenanceUrgency {
  emergency
  urgent
  routine
}

enum MaintenanceTrade {
  general
  plumbing
  electrical
  hvac
  appliance
  structural
  other
}

enum MaintenanceRequestSource {
  tenant_portal
  staff
  public_intake
  email_intake
}

enum MaintenanceOwnerApprovalStatus {
  not_required
  pending
  approved
  declined
}

enum MaintenanceAttachmentKind {
  photo
  video
  document
  other
}

model MaintenanceRequest {
  id             String @id @default(cuid())
  organizationId String
  propertyId     String
  unitId         String
  tenancyId      String

  submittedByContactId String?
  assignedToUserId     String?

  source MaintenanceRequestSource @default(tenant_portal)

  /// Optional free-form label alongside triage trade enum.
  category String?

  trade   MaintenanceTrade
  urgency MaintenanceUrgency       @default(routine)
  status  MaintenanceRequestStatus @default(new)

  title       String
  description String @db.Text

  isHabitable Boolean?
  accessNotes String?  @db.Text

  triageSummary String? @db.Text
  guidedMeta    Json?

  assignedVendorName String?
  completionNote     String? @db.Text

  ownerApprovalStatus MaintenanceOwnerApprovalStatus @default(not_required)
  ownerApprovedAt     DateTime?

  scheduledWorkAt DateTime?

  /// Reserved for PR7+ invoice workflow (object storage key).
  invoiceStorageKey String?
  invoiceAmount     Decimal? @db.Decimal(12, 2)

  /// Maps a row imported from Supabase maintenance_requests during one-time ETL.
  legacySupabaseId String? @unique

  submittedAt  DateTime  @default(now())
  dispatchedAt DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?

  organization       Organization            @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  property           Property                @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit               Unit                    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  tenancy            Tenancy                 @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  submittedByContact TenancyContact?         @relation(fields: [submittedByContactId], references: [id], onDelete: SetNull)
  assignedTo         User?                   @relation("MaintenanceRequestAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  attachments        MaintenanceAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([propertyId])
  @@index([unitId])
  @@index([tenancyId])
  @@index([status])
  @@index([urgency])
  @@index([trade])
  @@index([submittedByContactId])
  @@index([assignedToUserId])
  @@index([submittedAt])
}

model MaintenanceAttachment {
  id                   String @id @default(cuid())
  maintenanceRequestId String
  organizationId       String

  fileName    String
  contentType String?
  sizeBytes   Int?
  storageKey  String  @unique

  kind MaintenanceAttachmentKind @default(photo)

  uploadedByContactId String?
  uploadedByUserId    String?

  maintenanceRequest MaintenanceRequest @relation(fields: [maintenanceRequestId], references: [id], onDelete: Cascade)
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([maintenanceRequestId])
  @@index([organizationId])
}

/// Security and integration audit (Gmail connect/sync, AI drafts, OAuth). Separate from ActivityLog.
model AuditLog {
  id             String  @id @default(cuid())
  organizationId String?
  actorUserId    String
  action         String
  resourceType   String
  resourceId     String?
  metadata       Json?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor        User          @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
}

// --- Email (Gmail) — Phase 1: connect + tokens; Phase 2+: sync ---

enum ConnectedEmailAccountStatus {
  CONNECTED
  NEEDS_REAUTH
  REVOKED
}

model ConnectedEmailAccount {
  id             String @id @default(cuid())
  organizationId String
  userId         String

  provider        String                      @default("gmail")
  email           String
  externalId      String? /// Google sub / account id
  status          ConnectedEmailAccountStatus @default(CONNECTED)
  lastError       String?                     @db.Text
  lastSyncedAt    DateTime?
  /// Encrypted at application layer (see lib/crypto/token-vault.ts).
  refreshTokenEnc String?                     @db.Text
  accessTokenEnc  String?                     @db.Text
  accessExpiresAt DateTime?
  scopes          String[]

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connector                   User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  threads                     EmailThread[]
  emailSenderCategoryMemories EmailSenderCategoryMemory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, userId])
}

enum EmailThreadCategory {
  LANDLORD_COMMUNICATION
  TENANT_COMMUNICATION
  STRATA
  TENANT_INQUIRY
  UNCATEGORIZED
}

model EmailThread {
  id                 String    @id @default(cuid())
  organizationId     String
  connectedAccountId String
  providerThreadId   String
  subject            String?
  snippet            String?
  lastMessageAt      DateTime?
  labelIds           String[]  @default([])
  isUnread           Boolean   @default(false)
  participantEmails  String[]  @default([])

  /// Rocket PM inbox crate — dashboard source of truth (not Gmail labels).
  category            EmailThreadCategory @default(UNCATEGORIZED)
  categorySource      String?
  categoryUpdatedAt   DateTime?
  categoryConfidence            Float?
  categoryAiReason              String?   @db.Text
  lastClassificationAttemptAt   DateTime?

  /// Future: correlate to Core / Maintenance / etc. without tangling domains in code.
  contextLinks Json?

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedEmailAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  messages         EmailMessage[]
  drafts           AiDraftResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([connectedAccountId, providerThreadId])
  @@index([organizationId, lastMessageAt])
  @@index([organizationId, category, lastMessageAt])
}

/// Remembers which inbox crate a sender usually belongs to (per org + mailbox).
model EmailSenderCategoryMemory {
  id                 String              @id @default(cuid())
  organizationId     String
  connectedAccountId String
  senderEmail        String
  senderName         String?
  category           EmailThreadCategory
  contextNote        String?             @db.Text
  source             String
  createdByUserId    String?
  lastMatchedAt      DateTime?
  matchCount         Int                 @default(0)

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedEmailAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  createdBy        User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, connectedAccountId, senderEmail])
  @@index([organizationId, connectedAccountId])
}

model EmailMessage {
  id                String   @id @default(cuid())
  organizationId    String
  threadId          String
  providerMessageId String
  fromAddr          String
  toAddrs           String[]
  ccAddrs           String[]
  sentAt            DateTime
  bodyText          String?  @db.Text
  bodyHtml          String?  @db.Text
  isOutbound        Boolean  @default(false)
  labelIds          String[] @default([])
  isUnread          Boolean  @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       EmailThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  drafts AiDraftResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([threadId, providerMessageId])
  @@index([organizationId, sentAt])
}

// --- AI / knowledge (retrieval-based; no model training in V1) ---

enum AiKnowledgeSourceType {
  RULE
  WORKFLOW
  POLICY
  BC_CONTEXT
  APPROVED_EXAMPLE
  UPLOADED_THREAD_SUMMARY
}

model AiKnowledgeSource {
  id             String                @id @default(cuid())
  organizationId String
  type           AiKnowledgeSourceType
  title          String
  content        String                @db.Text
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, type])
}

model AiResponderRule {
  id             String  @id @default(cuid())
  organizationId String
  priority       Int     @default(0)
  title          String
  instruction    String  @db.Text
  active         Boolean @default(true)
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, active, priority])
}

model AiStyleExample {
  id             String  @id @default(cuid())
  organizationId String
  userId         String?
  title          String?
  content        String  @db.Text
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, userId])
}

model AiDraftResponse {
  id             String  @id @default(cuid())
  organizationId String
  threadId       String?
  messageId      String?

  createdByUserId String?
  model           String?
  promptVersion   String?
  status          AiDraftStatus @default(DRAFT)
  draftText       String?       @db.Text
  citations       Json?
  classification  Json?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  thread       EmailThread?  @relation(fields: [threadId], references: [id], onDelete: SetNull)
  message      EmailMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, createdAt])
}

enum AiDraftStatus {
  DRAFT
  APPROVED
  SUPERSEDED
}

// --- Background jobs & agent runs (Phase 0 framework; no automatic AI in Phase 0) ---

enum BackgroundJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum BackgroundJobTriggerSource {
  USER
  CRON
  SYSTEM
}

enum AgentRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

/// Per-org AI automation policy (defaults off until explicitly enabled in a future phase).
model OrganizationAiPolicy {
  id             String @id @default(cuid())
  organizationId String @unique

  autoTriageEnabled         Boolean @default(false)
  autoDraftEnabled          Boolean @default(false)
  maxAgentRunsPerDay        Int     @default(100)
  maxDraftGenerationsPerDay Int     @default(50)
  allowedAgentKeys          String[] @default([])

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackgroundJob {
  id             String @id @default(cuid())
  organizationId String

  jobType         String
  status          BackgroundJobStatus        @default(PENDING)
  priority        Int                        @default(0)
  idempotencyKey  String
  payload         Json?
  triggerSource   BackgroundJobTriggerSource
  triggeredByUserId String?

  scheduledAt DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  lastError   String?   @db.Text
  completedAt DateTime?

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  triggeredBy   User?        @relation("BackgroundJobTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  agentRun      AgentRun?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, jobType, idempotencyKey])
  @@index([status, scheduledAt])
  @@index([organizationId, createdAt])
}

model AgentRun {
  id             String @id @default(cuid())
  organizationId String

  agentKey       String
  agentVersion   String
  status         AgentRunStatus @default(PENDING)
  threadId       String?
  messageId      String?
  inputFingerprint String?
  model          String?
  tokenUsage     Json?
  outputKind     String?
  outputRefId    String?
  errorCode      String?
  errorMessage   String? @db.Text
  metadata       Json?

  createdByUserId  String?
  backgroundJobId  String? @unique

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?         @relation("AgentRunCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  backgroundJob  BackgroundJob? @relation(fields: [backgroundJobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, threadId, createdAt])
  @@index([agentKey, agentVersion, createdAt])
}
