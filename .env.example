# PostgreSQL connection string (SSL in production).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/rocket_pm_dashboard?schema=public"

# Auth.js / NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-long-random-string"
# Auth.js also accepts AUTH_SECRET / AUTH_URL (same values); middleware matches that order.

# Optional Google OAuth (sign-in)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Gmail OAuth (Phase 1+)
# You can reuse GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET if both redirect URIs are registered on the same client:
# - {NEXTAUTH_URL}/api/auth/callback/google
# - {NEXTAUTH_URL}/api/integrations/gmail/callback
# Or split credentials:
# GOOGLE_GMAIL_CLIENT_ID=""
# GOOGLE_GMAIL_CLIENT_SECRET=""
# Optional override if NEXTAUTH_URL is unset or your public URL differs:
# GOOGLE_GMAIL_REDIRECT_URI="http://localhost:3000/api/integrations/gmail/callback"

# Required in production before storing Gmail refresh tokens. Generate with: openssl rand -base64 32
GMAIL_TOKEN_ENCRYPTION_KEY=""

# Local dev only — never enable in production
# ALLOW_INSECURE_GMAIL_TOKEN_STORAGE="true"

# Optional separate secret for signing Gmail OAuth state (defaults to NEXTAUTH_SECRET)
# GMAIL_OAUTH_STATE_SECRET=""

# Gmail sync (Phase 2) — max threads per manual sync (1–100, default 50)
# GMAIL_SYNC_MAX_THREADS="50"

# Comma-separated Gmail label ids for threads.list (default INBOX)
# GMAIL_SYNC_LABEL_IDS="INBOX"

# OpenAI (Phase 3 AI responder)
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Dev-only credential provider (server)
DEV_CREDENTIALS_LOGIN="true"

# Mirrors server flag so the login form renders (safe locally only)
NEXT_PUBLIC_DEV_CREDENTIALS_LOGIN="true"
