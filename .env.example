# =============================================================================
# Rocket PM Dashboard — environment template (no real secrets)
# Copy to `.env` and fill in values for local development.
# =============================================================================

# --- Database (PostgreSQL) ---
# Pooled connection (app runtime). Use your host's pooled URL in production (e.g. Neon pooler).
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/rocket_pm_dashboard?schema=public"
# Direct connection (Prisma migrations / db push). Often the non-pooled URL on serverless Postgres hosts.
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/rocket_pm_dashboard?schema=public"

# --- Auth.js / NextAuth (staff sign-in) ---
# Public app URL (OAuth redirects). Auth.js also accepts AUTH_URL (same value).
NEXTAUTH_URL="http://localhost:3000"
# Session signing secret. Middleware also reads AUTH_SECRET if set.
NEXTAUTH_SECRET="replace-with-long-random-string"
# Optional aliases (same values as above):
# AUTH_URL="http://localhost:3000"
# AUTH_SECRET="replace-with-long-random-string"

# Optional Google OAuth for app sign-in (not Gmail mailbox connect):
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- Gmail OAuth (mailbox connect + sync + drafts) ---
# Register redirect URI: {NEXTAUTH_URL}/api/integrations/gmail/callback
# You may reuse GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET if both are registered on one client:
#   - {NEXTAUTH_URL}/api/auth/callback/google
#   - {NEXTAUTH_URL}/api/integrations/gmail/callback
# Or use dedicated Gmail credentials:
GOOGLE_GMAIL_CLIENT_ID=""
GOOGLE_GMAIL_CLIENT_SECRET=""
# Optional override when NEXTAUTH_URL is unset or the public URL differs:
# GOOGLE_GMAIL_REDIRECT_URI="http://localhost:3000/api/integrations/gmail/callback"

# Required in production before storing Gmail refresh tokens. Generate: openssl rand -base64 32
GMAIL_TOKEN_ENCRYPTION_KEY=""

# Local dev only — never enable in production
# ALLOW_INSECURE_GMAIL_TOKEN_STORAGE="true"

# Optional separate secret for signing Gmail OAuth state (defaults to NEXTAUTH_SECRET / AUTH_SECRET)
# GMAIL_OAUTH_STATE_SECRET=""

# Gmail manual sync — max threads per sync (1–100, default 50)
# GMAIL_SYNC_MAX_THREADS="50"
# Comma-separated label ids for threads.list (default INBOX)
# GMAIL_SYNC_LABEL_IDS="INBOX"

# --- Background jobs / agent framework (Phase 1) ---
# Secret for POST /api/internal/jobs/process (Vercel Cron sends Bearer CRON_SECRET when set)
# JOB_PROCESSOR_SECRET=""
# CRON_SECRET=""
# User id for AuditLog when jobs have no triggeredByUserId (e.g. cron drain). Use a seed staff user id locally.
# JOB_PROCESSOR_ACTOR_USER_ID=""
# Hours before inbox shows "Sync overdue" (default 24)
# GMAIL_SYNC_OVERDUE_HOURS="24"
# Future agent.* jobs — must stay false until agent handlers ship (default off if unset)
# AGENT_AUTOMATION_ENABLED="false"

# --- Gemini (AI responder) — @google/genai ---
GEMINI_API_KEY=""
# Optional; default gemini-2.5-flash when unset
# GEMINI_MODEL="gemini-2.5-flash"

# --- Maintenance public tenant intake (PR7) ---
# Organization slug allowed for unauthenticated POST /api/maintenance (default: axford)
# MAINTENANCE_PUBLIC_ORG_SLUG="axford"

# --- Tenant portal auth (Product PR 2) ---
# Optional dedicated HMAC secret for rocket_pm_tenant_session (defaults to NEXTAUTH_SECRET)
# TENANT_PORTAL_SESSION_SECRET=""
# Staging: return OTP in /api/portal/auth/start JSON when email is not wired yet
# TENANT_AUTH_DEV_SHOW_CODE="true"

# --- Staff credentials (NextAuth) ---
# Default password applied to admin@axford.test and pm@axford.test on db:seed (see docs/auth.md)
# SEED_STAFF_PASSWORD="AxfordDev123!"

# --- Development sign-in (never enable in production) ---
# When true, users without passwordHash can sign in with email only (password left empty)
DEV_CREDENTIALS_LOGIN="true"
NEXT_PUBLIC_DEV_CREDENTIALS_LOGIN="true"

# =============================================================================
# Production / staging (set in host secrets — see docs/deployment-checklist.md)
# =============================================================================
#
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."
# NEXTAUTH_URL="https://your-app.example.com"
# NEXTAUTH_SECRET="..."
# GOOGLE_GMAIL_CLIENT_ID="..."
# GOOGLE_GMAIL_CLIENT_SECRET="..."
# GOOGLE_GMAIL_REDIRECT_URI="https://your-app.example.com/api/integrations/gmail/callback"
# GMAIL_TOKEN_ENCRYPTION_KEY="..."   # openssl rand -base64 32
# GEMINI_API_KEY="..."
# MAINTENANCE_PUBLIC_ORG_SLUG="your-org-slug"
#
# DEV_CREDENTIALS_LOGIN="false"
# NEXT_PUBLIC_DEV_CREDENTIALS_LOGIN="false"
#
# Never in production:
# ALLOW_INSECURE_GMAIL_TOKEN_STORAGE
# SEED_STAFF_PASSWORD (seed is local/staging only — see docs/auth.md)
